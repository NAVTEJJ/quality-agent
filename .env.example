# Quality Agent — environment template
# Copy to .env and fill in your values, OR export these in your shell.

# ── AI ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_key_here

# ── Google OAuth (required for production auth gate) ──────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
# Application type: Web application
# Authorised redirect URI: http://localhost:8501  (or your production URL)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Random secret used to sign the auth cookie — change this in production.
AUTH_COOKIE_KEY=change_me_to_a_long_random_string

# URL Streamlit is served from (used as OAuth redirect URI).
REDIRECT_URI=http://localhost:8501

# ── Access control ────────────────────────────────────────────────────────────
ALLOWED_USERS_PATH=config/allowed_users.txt

# ── Data ──────────────────────────────────────────────────────────────────────
EXCEL_FILE_PATH=data/your_file.xlsx

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///data/processed/quality_agent.db

# ── API server ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
